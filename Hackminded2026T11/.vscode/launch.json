{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Uvicorn",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Frontend: Vite",
      "type": "shell",
      "command": "cmd /c npm run dev",
      "options": {
        "cwd": "${workspaceFolder}\\frontend"
      },
      "group": "build",
      "problemMatcher": []
    }
  ]
}
